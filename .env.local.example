# EmailJS — для отправки заявок с формы на email burchenkodima476@gmail.com
#
# Инструкция по настройке:
# 1. Зарегистрируйтесь на https://www.emailjs.com/ (бесплатно, 200 писем/мес)
# 2. Email Services → Add New Service → Gmail → войдите через burchenkodima476@gmail.com
#    Скопируйте Service ID
# 3. Email Templates → Create New Template:
#    - Subject:  Новая заявка — {{from_name}}
#    - To email: burchenkodima476@gmail.com
#    - В поле Content (режим HTML) вставьте только: {{{message_html}}}
#    Скопируйте Template ID
# 4. Account → API Keys → скопируйте Public Key
# 5. Скопируйте этот файл в .env.local и заполните значения ниже

NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxx
